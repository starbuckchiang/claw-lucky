# Server-side environment variables (P2-AI-02).
#
# This file documents required environment variables / Supabase Edge Function
# secrets. It contains NO real values. Do not commit `.env` with real secrets.

# --- AI Provider ---
AI_PROVIDER=gemini
AI_PROVIDER_MODEL=gemini-2.5-flash-image
AI_PROVIDER_TIMEOUT_MS=20000
AI_PROVIDER_MAX_RETRY=2
AI_PROVIDER_IMAGE_SIZE=1024x1792
AI_PROVIDER_SAFETY_LEVEL=BLOCK_MEDIUM_AND_ABOVE

# Gemini API key. Server-side ONLY (Supabase Edge Function secret).
# MUST NEVER be exposed to the browser, committed, or logged.
GEMINI_API_KEY=

# --- Supabase ---
# Public (safe to embed in the static frontend / config.js).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side ONLY (Supabase Edge Function secret). Used for persistence
# (generation/job/usage/points repositories) and Storage upload/signed URL
# generation. MUST NEVER be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Debug (optional) ---
# When "true", Provider Adapter logs may include a sanitized diagnostics
# object (still never prompt text / API key / base64).
AI_PROVIDER_DEBUG=false

# --- Provider Resilience Agent: Replicate FLUX fallback (OPTIONAL) ---
# Entirely optional. If REPLICATE_API_TOKEN is not set, no fallback provider
# is configured and the Provider Resilience Agent behaves exactly like a
# bare primary-only ProviderAdapter (no behavior change).
# Server-side ONLY (Supabase Edge Function secret). MUST NEVER be exposed to
# the browser, committed, or logged.
REPLICATE_API_TOKEN=
# Required only when REPLICATE_API_TOKEN is set. The Replicate model slug in
# "owner/model" format (NOT a version ID/hash) — used with Replicate's
# official model endpoint (/v1/models/{owner}/{model}/predictions).
# Example: black-forest-labs/flux-2-dev
REPLICATE_MODEL=
REPLICATE_POLL_INTERVAL_MS=2000
REPLICATE_MAX_POLL_ATTEMPTS=30

